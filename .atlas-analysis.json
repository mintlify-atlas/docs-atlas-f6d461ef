  "keyFeatures": [
    "Full GURPS Fourth Edition character creation and management",
    "Interactive character sheet editor with real-time point calculations",
    "Traits, advantages, disadvantages, and quirks management",
    "Skills, spells, and techniques with automatic level calculations",
    "Equipment and loot tracking with encumbrance calculations",
    "PDF and HTML/text export with customizable templates",
    "Library system for reusable traits, skills, spells, and equipment",
    "JavaScript-based scripting for custom prerequisites and calculations",
    "Campaign management for grouping related sheets",
    "Batch file conversion and synchronization via CLI",
    "Cross-platform support: macOS, Windows, Linux",
    "Internationalization (i18n) support"
  ],
  "publicApiSurface": [
    "gurps.Entity — core character data model",
    "gurps.Trait / gurps.TraitModifier — advantages, disadvantages, quirks",
    "gurps.Skill / gurps.Spell — skills and spells with level computation",
    "gurps.Equipment / gurps.EquipmentModifier — gear and modifiers",
    "gurps.Weapon — melee and ranged weapon stats",
    "gurps.AttributeDefs / gurps.Attributes — customizable character attributes",
    "gurps.Body / gurps.HitLocation — hit location tables",
    "gurps.Library / gurps.Libraries — content library management",
    "gurps.Settings / gurps.GlobalSettings() — application-wide settings",
    "gurps.SheetSettings — per-sheet configuration",
    "gurps.ExportSheets() — text/HTML template-based export",
    "gurps.Convert() — batch file format conversion",
    "gurps.SyncSheetsAndTemplates() — sync sheets with library sources",
    "gurps.FileInfo / gurps.KnownFileTypes — file type registry",
    "model/fxp.Int — fixed-point numeric type used throughout",
    "CLI flags: --convert, --sync, --text, --settings"
  ]
}
